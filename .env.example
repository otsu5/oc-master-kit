# ════════════════════════════════════════════════════════════
#  OC-Master v5 — 環境変数テンプレート
#  cp .env.example .env して値を編集してください
# ════════════════════════════════════════════════════════════

# ─── Telegram ─────────────────────────────────────────────
# BotFather から取得
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 承認権限を持つUserID（t.me/userinfobot で確認）
TELEGRAM_ADMIN_IDS=123456789
# ジョブ追加を許可するUserID（省略時はAdminのみ）
TELEGRAM_ALLOWED_IDS=

# ─── Paths (Windows Host) ─────────────────────────────────
OC_ROOT=C:\Users\SY\dev\OC

# ─── Paths (Container内) ──────────────────────────────────
OC_MOUNT=/oc
STAGING_MOUNT=/oc/staging
INBOX_MOUNT=/oc/inbox_raw
ASSETS_MOUNT=/oc/assets
VAULT_MOUNT=/oc/ObsidianVault
DB_PATH=/oc/agent/queue/oc_core.sqlite
LOG_DIR=/oc/agent/logs

# ─── Service URLs（コンテナ間通信） ──────────────────────
CORE_URL=http://core:8787
CORE_PORT=8787

# ─── Core API 認証トークン ────────────────────────────────
# 32文字以上のランダム文字列（必須）
# 生成例: openssl rand -hex 32
CORE_API_TOKEN=replace_with_64char_random_hex_string

# ─── Ollama（ローカルLLM・メインエンジン）────────────────
OLLAMA_BASE_URL=http://ollama:11434
# 軽量タスク用モデル（分類・要約・ルーティング）
OLLAMA_MODEL_LIGHT=qwen2.5-coder:7b
# 高精度タスク用モデル（設計・分析）
OLLAMA_MODEL_HEAVY=qwen2.5-coder:7b
# Ollama同時実行数上限（暴走防止）
OLLAMA_MAX_CONCURRENT=3

# ─── AI Providers（重量タスクのみ・BUDGET.ymlで制御）────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=

# ─── Miyabi Runtime（Phase2〜）───────────────────────────
MIYABI_BASE_URL=http://miyabi:9090

# ─── Discord（書庫モード・情報整理UI）───────────────────
# BotはDeveloper Portalから作成（MESSAGE CONTENT INTENT必須）
DISCORD_BOT_TOKEN=
# 完了ジョブのスレッド整理先チャンネル名
DISCORD_ARCHIVE_CHANNEL=oc-archive

# ─── GitHub ───────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=ShunsukeHayashi
GITHUB_REPO=your-target-repo

# ─── RunPod（Phase4〜・画像/動画生成）────────────────────
RUNPOD_API_KEY=
RUNPOD_COMFYUI_URL=
RUNPOD_DOWNLOAD_DIR=/oc/staging/generated

# ─── OpenWebUI ────────────────────────────────────────────
# openssl rand -hex 16
WEBUI_SECRET_KEY=replace_with_random_32char_string

# ─── Syncthing ────────────────────────────────────────────
# 管理画面: http://localhost:8384
# 初回セットアップ後にデバイスIDをメモすること

# ─── rclone バックアップ（Syncthingの削除リスク対策）────
RCLONE_REMOTE=mega
RCLONE_DEST=mega:oc-backup
